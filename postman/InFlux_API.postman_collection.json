    {
      "name": "Stations",
      "item": [
        {
          "name": "Get All Stations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stations?lat=18.5204&lng=73.8567&radius=10000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stations"],
              "query": [
                {"key": "lat", "value": "18.5204"},
                {"key": "lng", "value": "73.8567"},
                {"key": "radius", "value": "10000"}
              ]
            }
          }
        },
        {
          "name": "Get Station by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stations/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stations", ":id"],
              "variable": [
                {"key": "id", "value": ""}
              ]
            }
          }
        },
        {
          "name": "Create Station",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "name", "value": "New Station", "type": "text"},
                {"key": "address", "value": "123 Test St", "type": "text"},
                {"key": "location", "value": "{\"type\":\"Point\",\"coordinates\":[73.8567,18.5204]}", "type": "text"},
                {"key": "connectors", "value": "[{\"type\":\"CCS\",\"powerKw\":50,\"count\":2}]", "type": "text"},
                {"key": "availability", "value": "{\"totalSlots\":4,\"availableSlots\":2}", "type": "text"},
                {"key": "pricePerKwh", "value": "8.5", "type": "text"},
                {"key": "images", "type": "file", "src": []}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/stations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stations"]
            }
          }
        }
      ]
    },
